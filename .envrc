# .envrc (bootstrapped by init-devenv.sh)
# This enables direnv to use the project's flake devShell.
# Approve with: direnv allow

# If your direnv supports `use flake`, this is sufficient:
use flake

# Fallback: if `use flake` isn't available, you can export the nix shell manually:
# if [ -f flake.nix ]; then
#   eval "$(nix develop --command env)"
# fi
